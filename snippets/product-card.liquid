{%- comment -%}
  Renders a product card for collection grids and featured collections.
  Expects: product (product object)
{%- endcomment -%}

<article class="product-card">
  <div class="product-card-image aspect-{{ settings.product_card_aspect_ratio }}">
    <a href="{{ product.url }}" class="product-card-image-link" tabindex="-1" aria-hidden="true">
      {%- comment -%} Look for a 3D model in the product's media — Frood uses GLB pack renders on cards {%- endcomment -%}
      {%- assign primary_model = nil -%}
      {%- for media in product.media -%}
        {%- if media.media_type == 'model' -%}
          {%- assign primary_model = media -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if primary_model -%}
        {%- assign glb = primary_model.sources | where: 'format', 'glb' | first -%}
        {%- assign model_poster = primary_model.preview_image | default: product.featured_image -%}
        <product-card-model class="product-card-model" data-model="{{ glb.url }}">
          <canvas class="product-card-model-canvas"></canvas>
          {%- comment -%}
            Static poster shown until the live three.js render's first frame —
            and kept visible if WebGL is unavailable, the GLB fails to load, or
            the context is lost. Also covers total JS failure (e.g. a broken
            import map): the script never runs, so this image just stays.
          {%- endcomment -%}
          {%- if model_poster -%}
            {{
              model_poster
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
                width: model_poster.width,
                height: model_poster.height,
                class: 'product-card-model-fallback'
            }}
          {%- endif -%}
        </product-card-model>
      {%- elsif product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
            width: product.featured_image.width,
            height: product.featured_image.height
        }}

        {%- if product.media.size > 1 and product.media[1].media_type == 'image' -%}
          {{
            product.media[1]
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
              width: product.media[1].width,
              height: product.media[1].height,
              class: 'product-card-image-hover'
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card-placeholder"></div>
      {%- endif -%}
    </a>

    {%- comment -%} Badge priority: Sold out > Sale. The "new" auto-detect was removed. {%- endcomment -%}
    {%- liquid
      assign badge_text = ''
      assign badge_type = ''

      unless product.available
        assign badge_text = 'products.product.sold_out' | t
        assign badge_type = 'sold-out'
      endunless

      if badge_text == '' and product.compare_at_price > product.price
        assign badge_text = 'products.product.sale' | t
        assign badge_type = 'sale'
      endif
    -%}

    {%- if badge_text != '' -%}
      <span class="product-card-badge {{ badge_type }}">{{ badge_text }}</span>
    {%- endif -%}
  </div>

  <a href="{{ product.url }}" class="product-card-info">
    <h3 class="product-card-title text-ui">{{ product.title }}</h3>

    <div class="product-card-meta text-ui">
      {% render 'product-price', product: product %}

      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- if current_variant.weight > 0 -%}
        <span class="product-card-separator" aria-hidden="true">|</span>
        <span class="product-card-weight">
          {{- current_variant.weight | round -}}{{- current_variant.weight_unit -}}
        </span>
      {%- endif -%}
    </div>
  </a>
</article>

{%- comment -%}
  Custom three.js card render. The <product-card-model> web component (one per
  card) is drawn by a single shared WebGLRenderer — see assets/product-card-stage.js.
  Same module URL across every card render; the browser executes it once.
{%- endcomment -%}
<script type="module" src="{{ 'product-card-stage.js' | asset_url }}"></script>

{% stylesheet %}
  .product-card-info {
    padding-top: var(--spacing-s);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xxxs);
    text-align: center;
  }

  .product-card-title {
    margin: 0;
  }

  .product-card-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xxxs);
  }

  /* In product cards, price uses full body-ui styling (dark) rather than the muted .text-light */
  .product-card-meta .text-light {
    color: var(--color-text);
  }

  .product-card-image {
    position: relative;
    overflow: hidden;
    background-color: var(--color-bg-dark);
    border-radius: var(--rad-s);
  }

  /* 3D model render (GLB) — custom three.js, fills the card aspect box.
     .product-card-image keeps its --color-bg-dark background as the backdrop
     behind the model's transparent areas. The canvas + poster image are
     stacked (absolute); product-card-stage.js hides the poster once the live
     render's first frame lands, and re-shows it on any failure. */
  .product-card-model {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-card-model-canvas,
  .product-card-model-fallback {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-card-model-fallback {
    object-fit: cover;
  }

  /* product-card-stage.js hides the poster via the `hidden` attribute once the
     live render starts. The author `display: block` above outranks the UA
     `[hidden] { display: none }`, so the attribute needs an explicit rule. */
  .product-card-model-fallback[hidden] {
    display: none;
  }

  .product-card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .product-card-badge {
    position: absolute;
    top: var(--spacing-s);
    right: var(--spacing-s);
    background: var(--color-text);
    color: var(--color-bg);
    font-size: var(--font-size-mini);
    line-height: var(--line-height-mini);
    padding: var(--spacing-xxs) var(--spacing-xs);
  }

  .product-card-badge.sale {
    background: var(--color-accent);
    color: var(--color-text);
  }

{% endstylesheet %}
