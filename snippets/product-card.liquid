{%- comment -%}
  Renders a product card for collection grids and featured collections.
  Expects: product (product object)

  Media-type detection happens once at the top so the article body AND the
  conditional <script> tags can both reference the same variables. This is the
  whole point of Fix 1 — we only load product-card-stage.js (three.js, ~150KB)
  for cards with a 3D model, and product-card-hover-video.js for cards with a
  video. Pages with no GLB products skip three.js entirely.
{%- endcomment -%}

{%- assign primary_model = nil -%}
{%- assign hover_video = nil -%}
{%- assign video_src = nil -%}
{%- for media in product.media -%}
  {%- if primary_model == nil and media.media_type == 'model' -%}
    {%- assign primary_model = media -%}
  {%- endif -%}
  {%- if hover_video == nil and media.media_type == 'video' -%}
    {%- assign hover_video = media -%}
  {%- endif -%}
  {%- if primary_model and hover_video -%}{%- break -%}{%- endif -%}
{%- endfor -%}

{%- if hover_video -%}
  {%- assign video_src = hover_video.sources | where: 'format', 'mp4' | sort: 'width' | first -%}
{%- endif -%}

<article class="product-card">
  <div class="product-card-image aspect-{{ settings.product_card_aspect_ratio }}">
    <a href="{{ product.url }}" class="product-card-image-link" tabindex="-1" aria-hidden="true">
      {%- if primary_model -%}
        {%- assign glb = primary_model.sources | where: 'format', 'glb' | first -%}
        {%- assign model_poster = primary_model.preview_image | default: product.featured_image -%}
        <product-card-model class="product-card-model" data-model="{{ glb.url }}">
          <canvas class="product-card-model-canvas"></canvas>
          {%- comment -%}
            Static poster shown until the live three.js render's first frame —
            and kept visible if WebGL is unavailable, the GLB fails to load, or
            the context is lost. Also covers total JS failure (e.g. a broken
            import map): the script never runs, so this image just stays.
          {%- endcomment -%}
          {%- if model_poster -%}
            {{
              model_poster
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
                width: model_poster.width,
                height: model_poster.height,
                class: 'product-card-model-fallback'
            }}
          {%- endif -%}
        </product-card-model>
      {%- elsif product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
            width: product.featured_image.width,
            height: product.featured_image.height
        }}

        {%- if video_src -%}
          {%- comment -%}
            Hover overlay. The <img> above is the always-visible still
            (lazy-loaded, srcset). This <video> sits over it at opacity:0 and
            fades in only on .product-card:hover (CSS). JS handles data-src→src
            promotion after an 80ms hover-intent debounce, play, and reset-to-0
            on leave. preload="none" + data-src means zero MP4 bytes per card
            on initial page load — only fetched when the user actually settles
            on a card.
          {%- endcomment -%}
          <product-card-hover-video class="product-card-hover-video">
            <video
              class="product-card-video"
              muted
              playsinline
              preload="none"
              tabindex="-1"
              aria-hidden="true"
            >
              <source data-src="{{ video_src.url }}" type="video/mp4">
            </video>
          </product-card-hover-video>
        {%- elsif product.media.size > 1 and product.media[1].media_type == 'image' -%}
          {{
            product.media[1]
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
              width: product.media[1].width,
              height: product.media[1].height,
              class: 'product-card-image-hover'
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card-placeholder"></div>
      {%- endif -%}
    </a>

    {%- comment -%} Badge priority: Sold out > Sale. The "new" auto-detect was removed. {%- endcomment -%}
    {%- liquid
      assign badge_text = ''
      assign badge_type = ''

      unless product.available
        assign badge_text = 'products.product.sold_out' | t
        assign badge_type = 'sold-out'
      endunless

      if badge_text == '' and product.compare_at_price > product.price
        assign badge_text = 'products.product.sale' | t
        assign badge_type = 'sale'
      endif
    -%}

    {%- if badge_text != '' -%}
      <span class="product-card-badge {{ badge_type }}">{{ badge_text }}</span>
    {%- endif -%}
  </div>

  <a href="{{ product.url }}" class="product-card-info">
    <h3 class="product-card-title text-ui">{{ product.title }}</h3>

    <div class="product-card-meta text-ui">
      {% render 'product-price', product: product %}

      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- if current_variant.weight > 0 -%}
        <span class="product-card-separator" aria-hidden="true">|</span>
        <span class="product-card-weight">
          {{- current_variant.weight | round -}}{{- current_variant.weight_unit -}}
        </span>
      {%- endif -%}
    </div>
  </a>
</article>

{%- comment -%}
  Conditional script loading (Fix 1). 3D-model render and hover-video are
  mutually exclusive on a single card, so emit at most one script. Pages with
  no 3D products skip three.js entirely (~150KB); pages with no hover videos
  skip product-card-hover-video.js. Browser dedupes the fetch when multiple
  cards on the same page emit the same script tag.
{%- endcomment -%}
{%- if primary_model -%}
  <script type="module" src="{{ 'product-card-stage.js' | asset_url }}"></script>
{%- elsif video_src -%}
  <script type="module" src="{{ 'product-card-hover-video.js' | asset_url }}"></script>
{%- endif -%}

{% stylesheet %}
  .product-card-info {
    padding-top: var(--spacing-s);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xxxs);
    text-align: center;
  }

  .product-card-title {
    margin: 0;
  }

  .product-card-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xxxs);
  }

  /* In product cards, price uses full body-ui styling (dark) rather than the muted .text-light */
  .product-card-meta .text-light {
    color: var(--color-text);
  }

  .product-card-image {
    position: relative;
    overflow: hidden;
    border-radius: var(--rad-s);
  }

  /* 3D model render (GLB) — custom three.js, fills the card aspect box.
     The bg-dark sits on the model wrapper (not .product-card-image) so it only
     appears behind the GLB's transparent corners — video/image cards stay clean.
     product-card-stage.js hides the poster once the live render's first frame
     lands, and re-shows it on any failure. */
  .product-card-model {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
    background-color: var(--color-bg-dark);
  }

  .product-card-model-canvas,
  .product-card-model-fallback {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
  }

  .product-card-model-fallback {
    object-fit: cover;
  }

  /* product-card-stage.js hides the poster via the `hidden` attribute once the
     live render starts. The author `display: block` above outranks the UA
     `[hidden] { display: none }`, so the attribute needs an explicit rule. */
  .product-card-model-fallback[hidden] {
    display: none;
  }

  .product-card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  /* Hover video — sits over the always-visible <img>, faded in on
     .product-card:hover. Mirrors .product-card-image-hover (base.css §13) so
     the image-hover fallback and the video-hover treatment look identical.
     pointer-events: none keeps clicks routing to the underlying link. */
  .product-card-hover-video {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-fast);
    pointer-events: none;
  }

  .product-card-video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (hover: hover) {
    .product-card:hover .product-card-hover-video {
      opacity: 1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .product-card-hover-video {
      transition: none;
    }
    .product-card:hover .product-card-hover-video {
      opacity: 0;
    }
  }

  .product-card-badge {
    position: absolute;
    top: var(--spacing-s);
    right: var(--spacing-s);
    background: var(--color-text);
    color: var(--color-bg);
    font-size: var(--font-size-mini);
    line-height: var(--line-height-mini);
    padding: var(--spacing-xxs) var(--spacing-xs);
  }

  .product-card-badge.sale {
    background: var(--color-accent);
    color: var(--color-text);
  }

{% endstylesheet %}
