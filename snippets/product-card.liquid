{%- comment -%}
  Renders a product card for collection grids and featured collections.
  Expects: product (product object)
{%- endcomment -%}

<article class="product-card">
  <div class="product-card-image aspect-{{ settings.product_card_aspect_ratio }}">
    <a href="{{ product.url }}" class="product-card-image-link" tabindex="-1" aria-hidden="true">
      {%- comment -%} Look for a 3D model in the product's media — Frood uses GLB pack renders on cards {%- endcomment -%}
      {%- assign primary_model = nil -%}
      {%- for media in product.media -%}
        {%- if media.media_type == 'model' -%}
          {%- assign primary_model = media -%}
          {%- break -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if primary_model -%}
        {{ primary_model | model_viewer_tag: class: 'product-card-model', loading: 'lazy' }}
      {%- elsif product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
            width: product.featured_image.width,
            height: product.featured_image.height
        }}

        {%- if product.media.size > 1 and product.media[1].media_type == 'image' -%}
          {{
            product.media[1]
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              sizes: '(min-width: 1200px) 25vw, (min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
              width: product.media[1].width,
              height: product.media[1].height,
              class: 'product-card-image-hover'
          }}
        {%- endif -%}
      {%- else -%}
        <div class="product-card-placeholder"></div>
      {%- endif -%}
    </a>

    {%- comment -%} Badge priority: Sold out > Sale. The "new" auto-detect was removed. {%- endcomment -%}
    {%- liquid
      assign badge_text = ''
      assign badge_type = ''

      unless product.available
        assign badge_text = 'products.product.sold_out' | t
        assign badge_type = 'sold-out'
      endunless

      if badge_text == '' and product.compare_at_price > product.price
        assign badge_text = 'products.product.sale' | t
        assign badge_type = 'sale'
      endif
    -%}

    {%- if badge_text != '' -%}
      <span class="product-card-badge {{ badge_type }}">{{ badge_text }}</span>
    {%- endif -%}
  </div>

  <a href="{{ product.url }}" class="product-card-info">
    <h3 class="product-card-title text-ui">{{ product.title }} (4 pack)</h3>

    <div class="product-card-meta text-ui">
      {% render 'product-price', product: product %}

      {%- assign current_variant = product.selected_or_first_available_variant -%}
      {%- if current_variant.weight > 0 -%}
        <span class="product-card-separator" aria-hidden="true">|</span>
        <span class="product-card-weight text-h1">
          {{- current_variant.weight | round -}}{{- current_variant.weight_unit -}}
        </span>
      {%- endif -%}
    </div>
  </a>
</article>

{%- comment -%}
  Override Shopify's default model-viewer rendering attrs (tone-mapping, exposure, etc.) so
  the pack renders look like the source GLB (no ACES desaturation, no env-map reflections).
  The script is guarded so it only runs once per page even though this snippet renders many times.
{%- endcomment -%}
<script>
  if (!window.__froodModelTune) {
    window.__froodModelTune = true;
    customElements.whenDefined('model-viewer').then(() => {
      const tune = (el) => {
        el.toneMapping = 'neutral';
        el.exposure = 1;
        el.shadowIntensity = 0;
        el.environmentImage = 'neutral';
        el.interactionPrompt = 'none';
        /* Clear the Shopify-generated poster so the card bg-dark shows through during load
           instead of a letterboxed white-strip poster image. */
        el.poster = '';
      };
      document.querySelectorAll('.product-card-model').forEach(tune);
      new MutationObserver((records) => {
        records.forEach((r) => r.addedNodes.forEach((n) => {
          if (n.nodeType !== 1) return;
          if (n.classList && n.classList.contains('product-card-model')) tune(n);
          if (n.querySelectorAll) n.querySelectorAll('.product-card-model').forEach(tune);
        }));
      }).observe(document.body, { childList: true, subtree: true });
    });
  }
</script>

{% stylesheet %}
  .product-card-info {
    padding-top: var(--spacing-s);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xxxs);
    text-align: center;
  }

  .product-card-title {
    margin: 0;
  }

  .product-card-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-xxxs);
  }

  /* In product cards, price uses full body-ui styling (dark) rather than the muted .text-light */
  .product-card-meta .text-light {
    color: var(--color-text);
  }

  .product-card-image {
    position: relative;
    overflow: hidden;
    background-color: var(--color-bg-dark);
    border-radius: var(--rad-s);
  }

  /* 3D model render (GLB) — fills card aspect ratio */
  .product-card-model,
  .product-card-image model-viewer {
    width: 100%;
    height: 100%;
    display: block;
    background-color: transparent;
    --poster-color: transparent;
    --progress-bar-color: transparent;
    --progress-bar-height: 0px;
  }

  .product-card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .product-card-badge {
    position: absolute;
    top: var(--spacing-s);
    right: var(--spacing-s);
    background: var(--color-text);
    color: var(--color-bg);
    font-size: var(--font-size-mini);
    line-height: var(--line-height-mini);
    padding: var(--spacing-xxs) var(--spacing-xs);
  }

  .product-card-badge.sale {
    background: var(--color-accent);
    color: var(--color-text);
  }

{% endstylesheet %}
