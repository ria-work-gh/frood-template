{%- comment -%}
  Bundle cart panel — the "Your Box" summary.

  Shared between the bundle builder section (right column) and the cart drawer.
  Pure empty hooks: assets/bundle-cart-view.js (renderBundleCart) hydrates the
  [data-cart-*] hooks from the bundle store snapshot. Click handling for the
  per-line × buttons and [data-checkout] is owned by whichever component wraps
  this snippet (<bundle-builder> or <cart-drawer>) — both delegate to
  assets/bundle-store.js.

  Owner: assets/bundle-store.js + assets/bundle-cart-view.js
  Rendered by: sections/bundle-builder.liquid, sections/cart-drawer.liquid

  The co-located stylesheet ships wherever the snippet is rendered — the cart
  drawer is global, so the styles must travel with the snippet rather than
  living in the bundle-builder section (which only loads on the bundle page).
{%- endcomment -%}
<section
  class="bundle-cart"
  data-cart
  data-i18n-remove="{{ 'sections.bundle_builder.remove_item' | t }}"
>
  <p class="bundle-cart-empty" data-cart-empty>
    {{ 'sections.bundle_builder.empty_cart' | t }}
  </p>
  <ul class="bundle-cart-lines unstyled-list" data-cart-lines hidden></ul>
  <div class="bundle-cart-totals" data-cart-totals hidden>
    <div class="bundle-cart-totals-line">
      <span>{{ 'sections.bundle_builder.subtotal' | t }}</span>
      <span data-subtotal></span>
    </div>
    <div class="bundle-cart-totals-line bundle-cart-price-line">
      <span>{{ 'sections.bundle_builder.price' | t }}</span>
      <span data-price></span>
    </div>
  </div>
  <button type="button" class="button bundle-checkout" data-checkout hidden>
    {{ 'sections.bundle_builder.checkout' | t }}
  </button>
  <div class="form-error" data-error role="alert" hidden></div>
</section>

{% stylesheet %}
  .bundle-cart {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
    padding: var(--spacing-xxs);
    border-radius: var(--rad-s);
    background: var(--color-bg);
  }

  .bundle-cart-empty {
    margin: 0;
    font-size: var(--type-mini-size);
    color: var(--color-text-accent);
  }

  .bundle-cart-lines {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .bundle-cart-line {
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: start;
    gap: var(--spacing-xs);
  }

  .bundle-cart-qty {
    font-weight: 500;
  }

  .bundle-cart-meta {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .bundle-cart-name {
    margin: 0;
  }

  .bundle-cart-size {
    margin: 0;
    font-size: var(--type-mini-size);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-text-accent);
  }

  .bundle-cart-price {
    font-weight: 500;
  }

  .bundle-cart-remove {
    color: var(--color-text-accent);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
  }

  .bundle-cart-remove:hover {
    color: var(--color-text);
  }

  .bundle-cart-totals {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .bundle-cart-totals-line {
    display: flex;
    justify-content: space-between;
    font-size: var(--type-mini-size);
    color: var(--color-text-accent);
  }

  .bundle-cart-price-line {
    align-items: baseline;
    color: var(--color-text);
    font-weight: 500;
  }

  .bundle-cart-price-line [data-price] {
    display: inline-flex;
    gap: var(--spacing-xxxs);
    align-items: baseline;
  }

  .bundle-cart-strike {
    color: var(--color-text-accent);
    text-decoration: line-through;
  }

  .bundle-cart-saved {
    font-size: var(--type-mini-size);
    color: var(--color-text-accent);
  }

  .bundle-checkout {
    width: 100%;
  }
{% endstylesheet %}
