{%- comment -%}
  Placeholder Recipe Card — owned by sections/main-recipes.liquid.
  Card design is deliberately minimal for now (image + name + duration).
  Full card treatment (typography pairings, hover state, badges) lands later.
  Expects: recipe (metaobject)
{%- endcomment -%}

<article class="recipe-card">
  <a href="{{ recipe.system.url }}" class="recipe-card-link">
    <div class="recipe-card-image">
      {%- if recipe.image != blank -%}
        {{
          recipe.image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            sizes: '(min-width: 900px) 33vw, (min-width: 600px) 50vw, 100vw',
            width: recipe.image.width,
            height: recipe.image.height
        }}
      {%- else -%}
        <div class="recipe-card-placeholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>

    <div class="recipe-card-info">
      <h3 class="text-h3 recipe-card-name">{{ recipe.name }}</h3>
      {%- if recipe.duration != blank -%}
        <p class="text-ui recipe-card-duration">{{ recipe.duration }}</p>
      {%- endif -%}
    </div>
  </a>
</article>

{% stylesheet %}
  .recipe-card-link {
    display: grid;
    gap: var(--spacing-s);
  }

  .recipe-card-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background-color: var(--color-bg-dark);
    border-radius: var(--rad-s);
  }

  .recipe-card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recipe-card-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-border);
  }

  .recipe-card-info {
    display: grid;
    gap: var(--spacing-xxs);
  }

  .recipe-card-duration {
    color: var(--color-text-accent);
  }
{% endstylesheet %}
