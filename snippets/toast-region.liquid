{%- comment -%}
  Toast region — global transient feedback. Rendered once in layout/theme.liquid.
  Owns the toast markup via a clone <template>; assets/toast.js fills + mounts
  clones in response to the `toast:show` event. See assets/toast.js header for
  the full event contract. Owner: layout/theme.liquid.
{%- endcomment -%}
<toast-region class="toast-region" aria-live="polite">
  <template data-toast-template>
    <div class="toast" role="status">
      <span class="toast-message"></span>
      <button type="button" class="toast-close" data-dismiss aria-label="{{ 'accessibility.dismiss' | t }}">
        {% render 'icon-close' %}
      </button>
    </div>
  </template>
</toast-region>
<script type="module" src="{{ 'toast.js' | asset_url }}"></script>
