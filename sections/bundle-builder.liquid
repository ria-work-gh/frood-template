{%- comment -%}
  Bundle Builder — interactive "build your box" section (v3, box-first).

  The shopper fills ONE fixed box of BOX_CAPACITY (4) packs by mixing flavours,
  then adds the whole box to the native Shopify cart as a SINGLE line item at a
  flat price. There are no discount tiers and no multi-box draft — that was the
  old pouch-first v2 model.

  Two standalone web components, communicating only via `bundle:updated` on
  `document` (theme convention — see conventions/sections.md):

    <bundle-builder> (assets/bundle-builder.js)
      Owns the draft box (ordered list of packs, capped at capacity) + its
      localStorage persistence, the per-flavour steppers, and "Add to cart".
      Reads the .bundle-flavours JSON blob below for flavour name/notes/image.

    <bundle-stage> (assets/bundle-stage.js)
      Pure 2D PNG-compositing depth-stack visualiser (NO three.js). Listens for
      `bundle:updated` and stacks the box-back layer, the packs (newest at the
      front), and the box-front lip. Box-layer <img>s are server-rendered; pack
      images ride along in the event detail.

  ----------------------------------------------------------------------------
  DATA MODEL

  The box itself is ONE product (the "Build Your Box" product, priced at the
  flat box price) chosen in the section settings. On "Add to cart" the section
  POSTs that product's variant to /cart/add.js with the chosen flavours as a
  line-item property — the native cart treats it as any other line item.

  Flavours are CURATED PER BOX PRODUCT: the box product's
  `custom.included_flavours` metafield (a list of `flavour` metaobjects) sets
  which flavours show and in what order. Each referenced flavour metaobject
  needs these field handles:

    name        single_line_text_field  — flavour name ("Mexi Fiesta Blend")
    atrributes  single_line_text_field  — descriptors ("Smoky • Rich • Peppery") (optional)
                                          (field-handle typo lives in Shopify; rename
                                          there to `attributes` and update this file)
    image       file_reference (image)   — the pouch render PNG for the visualiser

  No box product (or an empty metafield) → no flavours render and add stays off.

  Box-layer renders (box-back / box-front) are merchant-overridable image
  settings; if unset they fall back to the committed placeholder theme assets
  (assets/box-back.png / box-front.png) pending the real Blender renders.

  Box capacity is locked at 4 (not a merchant setting) — the visualiser stack
  offsets are tuned for a 4-pack box.
{%- endcomment -%}

{%- assign capacity = 4 -%}
{%- assign box_product = section.settings.box_product -%}
{%- comment -%}
  Prefer the available variant (for price + a clean add); fall back to the first
  variant so the add button stays live even when nothing is "available" — the
  /cart/add.js call then surfaces a real "out of stock" error instead of the
  button silently sitting disabled.
{%- endcomment -%}
{%- assign box_variant = box_product.selected_or_first_available_variant | default: box_product.variants.first -%}
{%- comment -%} Curated, ordered list of flavour metaobjects, set per box product. {%- endcomment -%}
{%- assign included_flavours = box_product.metafields.custom.included_flavours.value -%}

{%- comment -%} Placeholder box renders are square (2048²); merchant overrides keep their own dims. {%- endcomment -%}
{%- if section.settings.box_back_image != blank -%}
  {%- assign box_back_url = section.settings.box_back_image | image_url: width: 1500 -%}
  {%- assign box_back_w = section.settings.box_back_image.width -%}
  {%- assign box_back_h = section.settings.box_back_image.height -%}
{%- else -%}
  {%- assign box_back_url = 'box-back.png' | asset_url -%}
  {%- assign box_back_w = 2048 -%}
  {%- assign box_back_h = 2048 -%}
{%- endif -%}
{%- if section.settings.box_front_image != blank -%}
  {%- assign box_front_url = section.settings.box_front_image | image_url: width: 1500 -%}
  {%- assign box_front_w = section.settings.box_front_image.width -%}
  {%- assign box_front_h = section.settings.box_front_image.height -%}
{%- else -%}
  {%- assign box_front_url = 'box-front.png' | asset_url -%}
  {%- assign box_front_w = 2048 -%}
  {%- assign box_front_h = 2048 -%}
{%- endif -%}

<bundle-builder
  class="bundle-builder color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
  data-capacity="{{ capacity }}"
  {% if box_variant %}data-box-variant-id="{{ box_variant.id }}"{% endif %}
  data-i18n-add="{{ 'sections.bundle_builder.add_to_cart' | t }}"
  data-i18n-added="{{ 'sections.bundle_builder.added' | t }}"
  data-i18n-contents="{{ 'sections.bundle_builder.contents_property' | t }}"
  data-i18n-error="{{ 'sections.bundle_builder.checkout_error' | t }}"
>
  <script type="application/json" class="bundle-flavours">
    [
      {%- for flavour in included_flavours -%}
        {
          "id": {{ flavour.system.handle | json }},
          "name": {{ flavour.name.value | json }},
          "attributes": {{ flavour.atrributes.value | default: '' | json }},
          "image": {% if flavour.image.value != blank %}{{ flavour.image.value | image_url: width: 1500 | json }}{% else %}""{% endif %}
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    ]
  </script>

  <div class="bundle-layout">
    <section class="bundle-panel">
      <header class="section-lockup">
        {%- if section.settings.eyebrow != blank -%}
          <h1 class="text-h1">{{ section.settings.eyebrow }}</h1>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="text-h3">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </header>

      <div class="bundle-flavour-list" data-flavour-list>
        {%- for flavour in included_flavours -%}
          <article
            class="bundle-flavour"
            data-flavour-card
            data-flavour-id="{{ flavour.system.handle }}"
            {%- if flavour.dark_colour != blank or flavour.light_colour != blank -%}
              style="
                {%- if flavour.dark_colour != blank -%}--flavour-dark: {{ flavour.dark_colour }};{%- endif -%}
                {%- if flavour.light_colour != blank -%}--flavour-light: {{ flavour.light_colour }};{%- endif -%}
              "
            {%- endif -%}
          >
            <div class="bundle-flavour-header">
              <div class="bundle-flavour-title">
                <h3 class="text-ui">{{ flavour.name }}</h3>
                {%- if flavour.atrributes != blank -%}
                  <p class="bundle-flavour-attributes">{{ flavour.atrributes }}</p>
                {%- endif -%}
              </div>
              {%- assign flavour_product = flavour.product_reference.value -%}
              {%- if flavour_product != blank -%}
                <a
                  class="bundle-flavour-link"
                  href="{{ flavour_product.url }}"
                  aria-label="{{ 'sections.bundle_builder.view_product' | t: name: flavour.name }}"
                >
                  <svg width="10" height="10" viewBox="0 0 7 7" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                    <path d="M0.753846 7L0 6.24615L5.16923 1.07692H0.538462V0H7V6.46154H5.92308V1.83077L0.753846 7Z"/>
                  </svg>
                </a>
              {%- endif -%}
            </div>
            <div class="bundle-stepper">
              <button
                type="button"
                data-action="remove"
                data-flavour-id="{{ flavour.system.handle }}"
                aria-label="{{ 'sections.bundle_builder.decrease' | t: name: flavour.name }}"
                disabled
              >
                <svg width="10" height="10" viewBox="0 0 7 1" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <path d="M0 1V0H7V1H0Z"/>
                </svg>
              </button>
              <span class="bundle-qty" data-qty="{{ flavour.system.handle }}">0</span>
              <button
                type="button"
                data-action="add"
                data-flavour-id="{{ flavour.system.handle }}"
                aria-label="{{ 'sections.bundle_builder.increase' | t: name: flavour.name }}"
              >
                <svg width="10" height="10" viewBox="0 0 7 7" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                  <path d="M3 4H0V3H3V0H4V3H7V4H4V7H3V4Z"/>
                </svg>
              </button>
            </div>
          </article>
        {%- else -%}
          <p class="bundle-flavour-attributes">{{ 'sections.bundle_builder.no_flavours' | t }}</p>
        {%- endfor -%}
      </div>

      <footer class="bundle-footer">
        {%- if box_variant -%}
          <div class="bundle-price-row text-ui">
            <span>{{ 'sections.bundle_builder.price' | t }}</span>
            <span>{{ box_variant.price | money }}</span>
          </div>
        {%- endif -%}

        <button type="button" class="button bundle-add" data-add disabled>
          <span class="bundle-add-inner">
            <span data-add-label>{{ 'sections.bundle_builder.add_to_cart' | t }}</span>
            <svg class="bundle-add-icon" width="16" height="12" viewBox="0 0 16 12" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
              <path d="M10 12L8.6 10.55L12.15 7H0V5H12.15L8.6 1.45L10 0L16 6L10 12Z"/>
            </svg>
          </span>
        </button>

        <div class="bundle-progress" data-progress role="progressbar" aria-valuemin="0" aria-valuemax="{{ capacity }}" aria-valuenow="0">
          <div class="bundle-progress-fill" data-progress-fill></div>
        </div>

        <div class="form-error" data-error role="alert" hidden></div>
      </footer>
    </section>

    <div class="bundle-visualiser">
      <bundle-stage class="bundle-stage" data-capacity="{{ capacity }}">
        <div class="bundle-scene" data-scene>
          <img class="bundle-layer bundle-box-back" src="{{ box_back_url }}" alt="" loading="lazy" width="{{ box_back_w }}" height="{{ box_back_h }}" data-box-back-img>
          <img class="bundle-layer bundle-box-front" src="{{ box_front_url }}" alt="" loading="lazy" width="{{ box_front_w }}" height="{{ box_front_h }}" data-box-front-img>
        </div>
      </bundle-stage>
    </div>
  </div>
</bundle-builder>

{% stylesheet %}
  .bundle-builder {
    display: block;
    padding: var(--spacing-m);
    color: var(--color-text);
  }

  .bundle-layout {
    display: flex;
    flex-direction: column-reverse;
    gap: var(--spacing-m);
    align-items: center;
    max-width: 1400px;
    margin-inline: auto;
  }

  /* Builder panel */
  .bundle-panel {
    /* Positioned so .bundle-progress can anchor to the panel's outer edges
       (left / right / bottom) and break out of the panel's inner padding. */
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-l);
    width: 100%;
    max-width: 460px;
    padding: var(--spacing-xs);
    background-color: var(--color-bg-dark);
  }

  /* Cap the panel's section heading at 36ch — matches the rest of the theme.
     Scoped via direct child of the lockup so the per-card flavour h3 stays
     unconstrained. */
  .bundle-panel > .section-lockup h3 {
    max-width: 36ch;
  }

  .bundle-flavour-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  /* Flavour card + stepper.
     Local tokens (--c-text / --c-text-accent / --c-bg) so the .is-active state
     can swap to the flavour's dark_colour + light_colour without re-stating
     every rule. Defaults map to the theme tokens; the active state overrides. */
  .bundle-flavour {
    --c-text: var(--color-text);
    --c-text-accent: var(--color-text-accent);
    --c-bg: var(--color-bg);
    --c-surface-muted: var(--color-bg-dark);

    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--spacing-m);
    padding: var(--spacing-xxs);
    border-radius: var(--rad-s);
    background: var(--c-bg);
    color: var(--c-text);
  }

  .bundle-flavour.is-active {
    --c-text: var(--flavour-dark, var(--color-text));
    --c-text-accent: color-mix(in srgb, var(--flavour-dark, var(--color-text)) 50%, transparent);
    /* Same dark @ 50% transparent as the attributes line — applied as bg for
       the muted buttons (disabled stepper + expand link). */
    --c-surface-muted: color-mix(in srgb, var(--flavour-dark, var(--color-text)) 50%, transparent);
    /* Light colour @ 50% composited over --color-bg (off-white), rendered as
       one opaque value so the result doesn't bleed through to the panel's
       beige bg. Equivalent to 0.5 × light + 0.5 × bg. */
    --c-bg: color-mix(in srgb, var(--flavour-light, var(--color-bg)) 50%, var(--color-bg));
  }

  .bundle-flavour-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-xs);
    width: 100%;
  }

  .bundle-flavour-title {
    display: flex;
    flex-direction: column;
    /* Was 0 before the global text-box trim landed — without natural leading,
       a 0 gap let the attributes line collide with the name's descenders. */
    gap: var(--spacing-xxs);
  }

  .bundle-flavour-title h3 {
    margin: 0;
  }

  .bundle-flavour-link {
    flex: none;
    width: 24px;
    height: 24px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--c-surface-muted);
    color: var(--c-text);
    border-radius: var(--rad-s);
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .bundle-flavour-link:hover,
  .bundle-flavour-link:focus-visible {
    background-color: var(--c-text);
    color: var(--color-bg);
  }

  .bundle-flavour-attributes {
    margin: 0;
    font-size: var(--type-mini-size);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-accent, var(--color-text-accent));
  }

  .bundle-stepper {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xxxs);
  }

  .bundle-stepper button {
    width: 24px;
    height: 24px;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: var(--c-text);
    color: var(--color-bg);
    border-radius: var(--rad-s);
    cursor: pointer;
  }

  .bundle-stepper button:disabled {
    background-color: var(--c-surface-muted);
    color: var(--c-text);
    cursor: default;
  }

  .bundle-qty {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 24px;
    font-size: var(--type-mini-size);
  }

  /* Footer: price row + add button + progress bar */
  .bundle-footer {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .bundle-price-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin: 0;
  }

  /* Dark variant of the primary .button: same shape/type as .button but with
     a muted bg until the box is full. Hover inverts to yellow on dark. */
  .bundle-add {
    width: 100%;
    background-color: var(--color-text-accent);
    color: var(--color-bg);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast);
  }

  /* When the box is full (= button enabled), bg shifts to the brand dark. */
  .bundle-add:not(:disabled) {
    background-color: var(--color-text);
  }

  .bundle-add:hover {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  /* Disabled-until-full state: keep the button visible (the progress bar below
     signals the build-up) but override .button:disabled's 0.6 opacity so the
     muted bg colour does the "not yet" signalling on its own. */
  .bundle-add:disabled {
    opacity: 1;
  }

  /* Inner flex wrapper — per the .button convention, never flex the button
     itself (breaks the global text-box trim) — flex an inner span instead. */
  .bundle-add-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--spacing-s);
  }

  /* Progress bar — thin track + fill that grows to capacity. Anchored to the
     panel's outer left/right/bottom edges so it sits as a flush bar on the
     container, ignoring the panel's inner padding. The fill width is set
     inline by bundle-builder.js render() from filled / capacity. */
  .bundle-progress {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 4px;
    background-color: var(--color-text-accent);
    overflow: hidden;
  }

  .bundle-progress-fill {
    width: 0;
    height: 100%;
    background-color: var(--color-text);
    transition: width var(--transition-slow);
  }

  /* Visualiser */
  .bundle-visualiser {
    width: 100%;
    max-width: 460px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bundle-stage {
    display: block;
    position: relative;
    width: 100%;
    /* Keep the layer z-indexes (box-back/packs/box-front) local — without a
       stacking context the box-front's z-index would leak to the root and paint
       over the cart drawer (z-index 99). */
    isolation: isolate;
  }

  /* Square frame matching the authoring render. overflow visible so packs
     shifted up-left in the stack aren't clipped. */
  .bundle-scene {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: visible;
  }

  .bundle-layer,
  .bundle-slot,
  .bundle-pack {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .bundle-layer,
  .bundle-pack {
    object-fit: contain;
  }

  .bundle-box-back {
    z-index: 0;
  }

  .bundle-box-front {
    z-index: 200;
  }

  /* A slot carries the depth transform; the inner pack carries enter/exit. */
  .bundle-slot {
    transform-origin: 50% 82%;
    transition: transform 0.32s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .bundle-pack {
    filter: drop-shadow(0 4px 8px var(--color-shadow-soft));
    transition: transform 0.34s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.34s ease;
  }

  .bundle-slot.is-entering .bundle-pack {
    transform: translateY(-12%);
    opacity: 0;
  }

  .bundle-slot.is-leaving .bundle-pack {
    transform: translateY(-8%);
    opacity: 0;
    transition-duration: 0.18s;
  }

  /* Desktop: builder left, visualiser fills remaining space and centers the scene */
  @media (min-width: 900px) {
    .bundle-layout {
      flex-direction: row;
      align-items: stretch;
      justify-content: flex-start;
      gap: var(--spacing-xl);
    }

    .bundle-panel {
      flex: none;
      width: 440px;
      max-width: 440px;
      justify-content: space-between;
    }

    .bundle-visualiser {
      flex: 1;
      max-width: none;
    }

    .bundle-stage {
      max-width: 600px;
      margin-inline: auto;
    }
  }

  /* Dev-only calibration overlay (toggle with ?bundle-calibrate in the URL) */
  .bundle-calib {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 400;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
    width: 220px;
    padding: var(--spacing-xxs);
    border-radius: var(--rad-s);
    background: var(--color-bg);
    color: var(--color-text);
    font-size: var(--type-mini-size);
  }

  .bundle-calib label {
    display: flex;
    flex-direction: column;
  }

  .bundle-calib input[type='range'] {
    width: 100%;
  }

  .bundle-calib code {
    word-break: break-all;
    font-size: 0.6rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .bundle-slot,
    .bundle-pack {
      transition: none;
    }
  }
{% endstylesheet %}

<script type="module" src="{{ 'bundle-builder.js' | asset_url }}"></script>
<script type="module" src="{{ 'bundle-stage.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Bundle builder",
  "tag": "section",
  "class": "bundle-builder-section",
  "settings": [
    {
      "type": "product",
      "id": "box_product",
      "label": "Box product",
      "info": "The single 'Build Your Box' product, priced at the flat box price. The chosen flavours are added to this product as a line-item property."
    },
    {
      "type": "paragraph",
      "content": "Flavours come from this product's 'Included flavours' metafield (custom.included_flavours) — a list of flavour metaobjects. Reorder there to reorder the cards. Each flavour needs a name, optional attributes, and an image. The box always holds 4 packs."
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Build your box"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Create and customise your box from the Frood selection."
    },
    {
      "type": "header",
      "content": "Box renders"
    },
    {
      "type": "paragraph",
      "content": "Optional overrides for the visualiser box layers. If unset, the placeholder renders shipped with the theme are used."
    },
    {
      "type": "image_picker",
      "id": "box_back_image",
      "label": "Box back layer",
      "info": "Carton with the front panel hidden — sits behind the packs."
    },
    {
      "type": "image_picker",
      "id": "box_front_image",
      "label": "Box front layer",
      "info": "Front panel / lip only — sits in front of the pack bases."
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Bundle builder"
    }
  ]
}
{% endschema %}
