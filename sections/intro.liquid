{%- comment -%}
  Frood Intro Section — top-of-page eyebrow (h1) + heading (h3).
  Padding: xl top, m on the other three sides.
  Uses .section-lockup (base.css §22) for the canonical xxs gap between h1 and h3.
{%- endcomment -%}

<section class="intro-section color-{{ section.settings.color_scheme }}">
  <div class="intro-section-lockup section-lockup">
    {%- if section.settings.eyebrow != blank -%}
      <h1 class="text-h1">{{ section.settings.eyebrow }}</h1>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h3 class="text-h3">{{ section.settings.heading | newline_to_br }}</h3>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .intro-section {
    padding: var(--spacing-xl) var(--spacing-m) var(--spacing-m);
    color: var(--color-text);
    background-color: var(--color-bg);
  }

  .intro-section h3 {
    max-width: 36ch;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Intro",
  "tag": "section",
  "class": "intro-section-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (h1 — small uppercase label)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (h3)",
      "info": "Press Enter to add a line break."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Intro"
    }
  ]
}
{% endschema %}
