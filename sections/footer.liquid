<footer class="footer color-{{ section.settings.color_scheme }}">
  <div class="footer-brand">
    <div class="footer-icon">{% render 'logo-frood' %}</div>
    {%- assign current_year = 'now' | date: '%Y' -%}
    <p class="footer-copyright text-h1">{{ 'footer.copyright' | t: year: current_year, shop_name: shop.name }}</p>
  </div>

  <div class="footer-right">
    <div class="footer-links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_list' -%}
          <div class="footer-column" {{ block.shopify_attributes }}>
            {%- if block.settings.heading != blank -%}
              <h2 class="footer-column-heading text-h1">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="footer-column-links">
                {%- for link in block.settings.menu.links -%}
                  <li>
                    <a href="{{ link.url }}" class="footer-link text-ui">{{ link.title }}</a>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'newsletter' -%}
        <div class="footer-newsletter" {{ block.shopify_attributes }}>
          <div class="footer-newsletter-text">
            {%- if block.settings.heading != blank -%}
              <h2 class="footer-newsletter-heading text-h1">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <p class="footer-newsletter-body text-body">{{ block.settings.body | newline_to_br }}</p>
            {%- endif -%}
          </div>
          {% render 'newsletter-form' %}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</footer>

{% stylesheet %}
  .footer {
    background-color: var(--color-bg);
    color: var(--color-text);
    padding: var(--spacing-xs);
    display: flex;
    /* Mobile + tablet: reversed column so the icon brand block sits at the bottom */
    flex-direction: column-reverse;
    align-items: center;
    gap: var(--spacing-l);
  }

  /* On wider viewports: brand left, links + newsletter right, with space between.
     Section padding also bumps from xs to m at this breakpoint. */
  @media (min-width: 900px) {
    .footer {
      padding: var(--spacing-m);
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
      gap: var(--spacing-m);
    }
  }

  /* Brand (left on desktop, bottom on mobile + tablet) */
  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-xxs);
    flex: 0 0 auto;
    width: 100%;
  }

  @media (min-width: 900px) {
    .footer-brand {
      width: auto;
      align-items: flex-start;
    }
  }

  .footer-icon {
    width: 80%;
    color: var(--color-text);
  }

  @media (min-width: 900px) {
    .footer-icon {
      width: 500px;
    }
  }

  .footer-icon svg {
    width: 100%;
    height: auto;
    display: block;
  }

  .footer-copyright {
    margin: 0;
  }

  /* Right block (links + newsletter stacked) */
  .footer-right {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-l);
    flex: 1;
    max-width: 640px;
  }

  /* Links grid (2 columns) */
  .footer-links {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--spacing-m);
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
  }

  .footer-column-heading {
    margin: 0;
  }

  .footer-column-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  .footer-link {
    color: var(--color-text);
    text-decoration: none;
  }

  .footer-link:hover {
    text-decoration: underline;
  }

  /* Newsletter (below links grid) */
  .footer-newsletter {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  .footer-newsletter-text {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
  }

  .footer-newsletter-heading,
  .footer-newsletter-body {
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Navigation column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Newsletter"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Body copy",
          "default": "Be the first to hear about new ingredients, recipes, and limited drops."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer",
      "blocks": [
        {
          "type": "link_list"
        },
        {
          "type": "link_list"
        },
        {
          "type": "newsletter"
        }
      ]
    }
  ]
}
{% endschema %}
