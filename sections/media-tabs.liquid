{%- comment -%}
  Frood Media Tabs — full-bleed video background with a vertical stack of tabs on the
  left-center. Each tab has an h1, a body description, and an attached video. Active tab
  reveals its description and plays its video full-bleed. When the video ends, the next
  tab is activated automatically (looping back to the first). Tabs can also be clicked.
{%- endcomment -%}

<section class="media-tabs-section color-{{ section.settings.color_scheme }}">
  <media-tabs class="media-tabs">
    <div class="media-tabs-videos" aria-hidden="true">
      {%- for block in section.blocks -%}
        <div
          class="media-tabs-video{% if forloop.first %} is-active{% endif %}"
          data-video-index="{{ forloop.index0 }}"
        >
          {%- if block.settings.video != blank -%}
            <video
              class="media-tabs-video-el"
              muted
              playsinline
              preload="metadata"
            >
              {%- for source in block.settings.video.sources -%}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {%- endfor -%}
            </video>
          {%- else -%}
            <div class="media-tabs-video-placeholder"></div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>

    <div class="media-tabs-overlay">
      <ul class="media-tabs-list">
        {%- for block in section.blocks -%}
          <li {{ block.shopify_attributes }}>
            <button
              type="button"
              class="media-tab-button{% if forloop.first %} is-active{% endif %}"
              data-tab-index="{{ forloop.index0 }}"
              aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
            >
              {%- if block.settings.heading != blank -%}
                <h2 class="text-h1 media-tab-heading">{{ block.settings.heading }}</h2>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <div class="text-body media-tab-description">{{ block.settings.description }}</div>
              {%- endif -%}
            </button>
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </media-tabs>
</section>

<script type="module" src="{{ 'media-tabs.js' | asset_url }}"></script>

{% stylesheet %}
  .media-tabs-section {
    color: var(--color-text);
    background-color: var(--color-bg);
  }

  .media-tabs {
    position: relative;
    display: block;
    width: 100%;
    height: 100vh;
    overflow: hidden;
  }

  .media-tabs-videos {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .media-tabs-video {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .media-tabs-video.is-active {
    opacity: 1;
  }

  .media-tabs-video-el,
  .media-tabs-video-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-tabs-video-placeholder {
    background: var(--color-bg-dark);
  }

  .media-tabs-overlay {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    padding: var(--spacing-m);
    pointer-events: none;
  }

  .media-tabs-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxs);
    max-width: 320px;
    pointer-events: auto;
  }

  .media-tab-button {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-m);
    width: 100%;
    background-color: var(--color-bg-dark);
    color: var(--color-text);
    padding: var(--spacing-xxs);
    border: 0;
    border-radius: var(--rad-s);
    text-align: left;
    cursor: pointer;
    opacity: 0.7;
    transition: opacity var(--transition-fast);
    font: inherit;
  }

  .media-tab-button.is-active {
    opacity: 1;
  }

  .media-tab-heading {
    margin: 0;
  }

  .media-tab-description {
    margin: 0;
    display: none;
  }

  .media-tab-button.is-active .media-tab-description {
    display: block;
  }

  .media-tab-description p {
    margin: 0;
  }

  .media-tab-description p + p {
    margin-top: var(--spacing-xxs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Media tabs",
  "tag": "section",
  "class": "media-tabs-section-wrapper",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading (h1 — small uppercase label)"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Media tabs",
      "blocks": [
        { "type": "tab" },
        { "type": "tab" },
        { "type": "tab" }
      ]
    }
  ]
}
{% endschema %}
