{%- comment -%}
  Frood Full-bleed — large image at viewport height (100vh or 75vh).
  Optional outer margins (padding m around the section) and an optional caption card
  sitting inside the image with xxs offset from the image edges.
{%- endcomment -%}

<section
  class="fullbleed-section color-{{ section.settings.color_scheme }} height-{{ section.settings.height }}{% if section.settings.margins %} has-margins{% endif %}"
>
  <div class="fullbleed-frame">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          widths: '375, 750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          width: section.settings.image.width,
          height: section.settings.image.height,
          class: 'fullbleed-image'
      }}
    {%- else -%}
      <div class="fullbleed-image placeholder" aria-hidden="true"></div>
    {%- endif -%}

    {%- if section.settings.caption_heading != blank or section.settings.caption_body != blank -%}
      <div class="fullbleed-caption">
        {%- if section.settings.caption_heading != blank -%}
          <h1 class="text-h1">{{ section.settings.caption_heading }}</h1>
        {%- endif -%}
        {%- if section.settings.caption_body != blank -%}
          <div class="fullbleed-caption-body text-body">{{ section.settings.caption_body }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .fullbleed-section {
    color: var(--color-text);
    background-color: var(--color-bg);
  }

  .fullbleed-section.height-100 { height: 100vh; }
  .fullbleed-section.height-75 { height: 75vh; }

  .fullbleed-section.has-margins {
    padding: var(--spacing-xs);
  }

  @media (min-width: 900px) {
    .fullbleed-section.has-margins {
      padding: var(--spacing-m);
    }
  }

  .fullbleed-frame {
    position: relative;
    width: 100%;
    height: 100%;
    padding: var(--spacing-xxs);
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
  }

  .fullbleed-frame::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--color-overlay);
    pointer-events: none;
    z-index: 1;
  }

  .fullbleed-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .fullbleed-image.placeholder {
    background: var(--color-bg-dark);
  }

  .fullbleed-caption {
    position: relative;
    z-index: 2;
    background-color: var(--color-bg-dark);
    border-radius: var(--rad-s);
    padding: var(--spacing-xxs);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
    max-width: 36ch;
  }

  .fullbleed-caption p {
    margin: 0;
  }

  /* Richtext caption body — kill default p spacing, keep paragraph gaps tight */
  .fullbleed-caption-body p + p {
    margin-top: var(--spacing-xxs);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Full-bleed",
  "tag": "section",
  "class": "fullbleed-section-wrapper",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "100", "label": "Full viewport (100vh)" },
        { "value": "75", "label": "Three-quarters viewport (75vh)" }
      ],
      "default": "100"
    },
    {
      "type": "checkbox",
      "id": "margins",
      "label": "Margins",
      "info": "When on, the image sits inside section padding. When off, it goes edge-to-edge.",
      "default": false
    },
    {
      "type": "header",
      "content": "Caption"
    },
    {
      "type": "text",
      "id": "caption_heading",
      "label": "Caption heading (h1 — small uppercase label)"
    },
    {
      "type": "richtext",
      "id": "caption_body",
      "label": "Caption body"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Full-bleed"
    }
  ]
}
{% endschema %}
