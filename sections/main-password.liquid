<div
  class="password color-{{ section.settings.color_scheme }}{% if section.settings.background_image != blank %} has-background-image{% endif %}"
  style="--password-overlay-alpha: {{ section.settings.overlay_opacity }}%;"
>
  {%- if section.settings.background_image != blank -%}
    {{
      section.settings.background_image
      | image_url: width: 2400
      | image_tag:
        loading: 'eager',
        widths: '375, 750, 1100, 1500, 2000, 2400',
        sizes: '100vw',
        width: section.settings.background_image.width,
        height: section.settings.background_image.height,
        class: 'password-bg',
        alt: ''
    }}
  {%- endif -%}

  <div class="password-logo">
    {% render 'logo-frood' %}
  </div>

  <div class="password-container">
    <h1 class="password-heading text-h2">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ 'password.general.title' | t }}
      {%- endif -%}
    </h1>

    <div class="password-form-wrapper password-form-wrapper-newsletter">
      {% form 'customer', id: 'password-newsletter', class: 'password-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div class="form-inline">
          <label for="password-newsletter-email" class="visually-hidden">
            {{ 'newsletter.email_placeholder' | t }}
          </label>
          <input
            type="email"
            id="password-newsletter-email"
            name="contact[email]"
            class="input text-ui"
            placeholder="{{ 'newsletter.email_placeholder' | t }}"
            autocomplete="email"
            required
            {% if form.posted_successfully? %}disabled{% endif %}
          >
          <button type="submit" class="button">
            {{ 'newsletter.submit' | t }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <p class="form-success text-body" role="alert">
            {{ 'newsletter.success' | t }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="form-error text-body" role="alert">
            {{ form.errors.translated_fields.email | default: 'newsletter.error' | t }}
          </div>
        {%- endif -%}
      {% endform %}
    </div>

    <div class="password-form-wrapper password-form-wrapper-store">
      {% form 'storefront_password', class: 'password-form password-form-store' %}
        <div class="form-inline">
          <label for="password-input" class="visually-hidden">
            {{ 'password.general.password_label' | t }}
          </label>
          <input
            type="password"
            id="password-input"
            name="password"
            class="input text-ui"
            placeholder="{{ 'password.general.password_placeholder' | t }}"
            required
          >
          <button type="submit" class="button">
            {{ 'password.general.enter' | t }}
          </button>
        </div>

        {%- if form.errors -%}
          <div class="form-error text-body" role="alert">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}
      {% endform %}
    </div>

    <p class="password-admin text-body">
      {{ 'password.general.admin_link' | t | split: 'Log in here' | first }}
      <a href="#password" class="inline-link" data-show-password>Log in here</a>
    </p>
  </div>
</div>

<script>
  (function () {
    var root = document.currentScript.previousElementSibling;
    while (root && !root.classList.contains('password')) {
      root = root.previousElementSibling;
    }
    if (!root) return;

    function showPasswordForm() {
      root.classList.add('show-password-form');
      var input = root.querySelector('#password-input');
      if (input) input.focus();
    }

    root.addEventListener('click', function (e) {
      var trigger = e.target.closest('[data-show-password]');
      if (!trigger) return;
      e.preventDefault();
      showPasswordForm();
    });

    if (window.location.hash === '#password') {
      showPasswordForm();
    }
  })();
</script>

{% stylesheet %}
  .password-section {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .password {
    position: relative;
    width: 100%;
    min-height: 100vh;
    min-height: 100dvh;
    padding: var(--spacing-m) var(--spacing-base);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    overflow: hidden;
  }

  .password-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .password.has-background-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background-color: color-mix(in srgb, var(--color-text) var(--password-overlay-alpha, 10%), transparent);
    pointer-events: none;
    z-index: 1;
  }

  .password-logo {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 35vw;
    max-width: 420px;
    color: var(--color-accent);
  }

  .password-logo svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .password-container {
    position: relative;
    z-index: 2;
    max-width: 480px;
    width: 100%;
    color: var(--color-bg);
  }

  .password-container .inline-link {
    text-decoration-color: var(--color-bg);
  }

  .password-heading {
    margin-bottom: var(--spacing-s);
  }

  .password-form-wrapper {
    margin-bottom: var(--spacing-m);
  }

  /* Default: show newsletter, hide store password form */
  .password-form-wrapper-store {
    display: none;
  }

  /* Toggled on by JS when "Log in here" is clicked */
  .password.show-password-form .password-form-wrapper-newsletter {
    display: none;
  }

  .password.show-password-form .password-form-wrapper-store {
    display: block;
  }

  .password.show-password-form .password-admin {
    display: none;
  }

  /* Auto-show password form on server-side error (after a failed submit) */
  .password:has(.password-form-store .form-error) .password-form-wrapper-newsletter {
    display: none;
  }

  .password:has(.password-form-store .form-error) .password-form-wrapper-store {
    display: block;
  }

  .password:has(.password-form-store .form-error) .password-admin {
    display: none;
  }

  .password-form .form-error,
  .password-form .form-success {
    color: var(--color-text);
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
    margin-top: var(--spacing-xxs);
    margin-bottom: 0;
  }

  .password-form .form-inline {
    gap: var(--spacing-xxs);
  }

  /* Input styled to match the bento nav-link buttons in the header */
  .password-form .input {
    background-color: var(--color-nav);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-border);
    border-radius: var(--rad-s);
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }

  .password-form .input:hover {
    background-color: var(--color-bg);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .password-form .input:focus,
  .password-form .input:focus-visible {
    background-color: var(--color-bg);
    border-color: transparent;
    outline: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .password-form .input::placeholder {
    color: var(--color-text);
    opacity: 0.7;
  }

  /* Match the nav-link's tighter horizontal padding */
  .password-form .button {
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
  }

  .password-admin {
    margin-top: var(--spacing-m);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Password page",
  "tag": "section",
  "class": "password-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Optional. Full-bleed behind the password card."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity",
      "info": "Darken the background image for legibility. Only applies when a background image is set.",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Leave blank to use default translation"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
