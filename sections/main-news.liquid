{%- comment -%}
  Frood News index — vertical stack of news cards. No section header (intentional).
  Loops through every entry of the `news` metaobject definition.

  Note: the metaobject type handle is referenced as `shop.metaobjects.news`.
  If the type handle in admin differs (e.g. `news_post`, `news_item`), swap the dot-key.
  See CLAUDE.md → "Snippet Ownership" — `news-card` is owned by this section.
{%- endcomment -%}

<section class="news-index color-{{ section.settings.color_scheme }}">
  {%- comment -%}
    Filter out entries flagged as past events — those are owned by the
    Event Slider section. `unless` catches both `false` AND unset (null) values,
    so untoggled entries default to appearing in the index.
  {%- endcomment -%}
  {%- assign all_news = shop.metaobjects.news.values -%}
  {%- assign visible_count = 0 -%}
  {%- for item in all_news -%}
    {%- unless item.add_to_previous_events -%}
      {%- assign visible_count = visible_count | plus: 1 -%}
    {%- endunless -%}
  {%- endfor -%}

  {%- if visible_count > 0 -%}
    <div class="news-index-grid">
      {%- for item in all_news -%}
        {%- unless item.add_to_previous_events -%}
          {% render 'news-card', news: item %}
        {%- endunless -%}
      {%- endfor -%}
    </div>
  {%- else -%}
    <p class="news-index-empty text-body">
      {{ 'news.index.empty' | t }}
    </p>
  {%- endif -%}
</section>

{% stylesheet %}
  .news-index {
    padding: var(--spacing-xs);
    color: var(--color-text);
    background-color: var(--color-bg);
  }

  @media (min-width: 900px) {
    .news-index {
      padding: var(--spacing-m);
    }
  }

  /* News cards stack vertically — one card per row at every breakpoint.
     Hairline between entries: symmetric m padding-block on each card with a
     border-top on non-first cards puts the hairline visually centered in the
     gap between two cards. First card has no top padding/border; last card
     has no bottom padding. */
  .news-index-grid {
    display: flex;
    flex-direction: column;
  }

  .news-index-grid .news-card {
    padding-block: var(--spacing-m);
  }

  .news-index-grid .news-card:not(:first-child) {
    border-top: 1px solid var(--color-text);
  }

  .news-index-grid .news-card:first-child {
    padding-top: 0;
  }

  .news-index-grid .news-card:last-child {
    padding-bottom: 0;
  }

  .news-index-empty {
    padding: var(--spacing-l) 0;
    color: var(--color-text-accent);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "News index",
  "tag": "section",
  "class": "news-index-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "News index"
    }
  ]
}
{% endschema %}
