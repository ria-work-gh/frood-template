<header class="header color-{{ section.settings.color_scheme }}">
  {%- comment -%} Mobile (<600px): "Menu" disclosure button that drops a panel of links below {%- endcomment -%}
  <details class="header-mobile-menu">
    <summary class="header-mobile-toggle text-ui">Menu</summary>
    <nav class="header-mobile-panel" aria-label="{{ 'header.navigation' | t }}">
      {%- for link in linklists[section.settings.menu].links -%}
        <a href="{{ link.url }}" class="nav-link text-ui">{{ link.title }}</a>
      {%- endfor -%}
    </nav>
  </details>

  {%- comment -%} Tablet+ (≥600px): bento nav grid {%- endcomment -%}
  <nav class="header-nav" aria-label="{{ 'header.navigation' | t }}">
    {%- for link in linklists[section.settings.menu].links -%}
      <a href="{{ link.url }}" class="nav-link text-ui">{{ link.title }}</a>
    {%- endfor -%}
  </nav>

  <div class="header-right">
    <cart-icon data-aria-template="{{ 'accessibility.cart_count' | t: count: '__COUNT__' }}">
      <a
        href="{{ routes.cart_url }}"
        class="header-cart text-ui"
        aria-label="{{ 'accessibility.cart_count' | t: count: cart.item_count }}"
      >
        {{ 'header.cart' | t }} (<span class="cart-count">{{ cart.item_count }}</span>)
      </a>
    </cart-icon>
  </div>
</header>

<script src="{{ 'cart-icon.js' | asset_url }}" defer></script>

<script>
  (function () {
    var group = document.querySelector('.shopify-section-group-header-group');
    if (!group || group.children.length < 2) return;

    var firstSection = group.firstElementChild;
    function measure() {
      var h = firstSection.offsetHeight;
      group.style.setProperty('--header-group-offset', h + 'px');
    }

    measure();

    var ro = new ResizeObserver(measure);
    ro.observe(firstSection);
  })();
</script>

{% stylesheet %}
  :root {
    --header-height: 52px;
  }

  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 9;
    background-color: transparent;
    color: var(--color-text);
    padding: var(--spacing-xxs);
    /* Mobile: flex layout so "Menu" disclosure fills space next to cart */
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-xxxs);
  }

  @media (min-width: 600px) {
    .header {
      /* Tablet+: revert to block layout so bento can center / cart can position absolutely */
      display: block;
    }
  }


  /* Mobile menu disclosure — "Menu" summary + dropdown panel */
  .header-mobile-menu {
    flex: 1;
    min-width: 0;
    position: relative;
  }

  .header-mobile-toggle {
    display: block;
    width: 100%;
    cursor: pointer;
    list-style: none;
    /* Same bento card styling as .nav-link */
    background-color: var(--color-nav);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-border);
    border-radius: var(--rad-s);
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
    text-align: left;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }

  .header-mobile-toggle::-webkit-details-marker {
    display: none;
  }

  .header-mobile-toggle:hover {
    background-color: var(--color-accent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .header-mobile-menu[open] .header-mobile-toggle {
    background-color: var(--color-accent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  /* Dropdown panel — vertical stack below the toggle */
  .header-mobile-panel {
    position: absolute;
    top: calc(100% + var(--spacing-xxxs));
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
  }

  /* Inside the dropdown, nav-links go full width and ignore the bento grid-column */
  .header-mobile-panel .nav-link {
    grid-column: auto;
    display: block;
    width: 100%;
  }

  /* Hide the mobile disclosure at tablet+ */
  @media (min-width: 600px) {
    .header-mobile-menu {
      display: none;
    }
  }

  /* Bento nav — hidden on mobile; 6-col grid on tablet+ */
  .header-nav {
    display: none;
  }

  @media (min-width: 600px) {
    .header-nav {
      max-width: 400px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      column-gap: var(--spacing-xxxs);
      row-gap: var(--spacing-xxxs);
    }
  }

  /* Tablet (600–899px): left-align the bento so it sits opposite the right-aligned cart */
  @media (min-width: 600px) and (max-width: 899px) {
    .header-nav {
      margin: 0;
    }
  }

  .nav-link {
    /* default: 1/3 width (3 cells per row of 6 columns = span 2) */
    grid-column: span 2;
    background-color: var(--color-nav);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-border);
    border-radius: var(--rad-s);
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
    text-align: left;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }

  .nav-link:hover {
    background-color: var(--color-accent);
    color: var(--color-text);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    opacity: 1;
  }

  .nav-link:active {
    background-color: var(--color-text);
    color: var(--color-accent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    opacity: 1;
  }

  /* First two links span half the grid (3 of 6 columns each) */
  .nav-link:nth-child(1),
  .nav-link:nth-child(2) {
    grid-column: span 3;
  }

  /* Cart: in the flex flow on mobile (next to menu), absolutely positioned top-right on tablet+ */
  .header-right {
    flex-shrink: 0;
  }

  @media (min-width: 600px) {
    .header-right {
      position: absolute;
      top: var(--spacing-xxs);
      right: var(--spacing-xxs);
    }
  }

  .header-cart {
    display: inline-block;
    background-color: var(--color-nav);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    border: 1px solid var(--color-border);
    border-radius: var(--rad-s);
    padding: var(--spacing-xxs) var(--spacing-xxs) 7px;
    color: var(--color-text);
    transition: background-color var(--transition-fast);
  }

  .header-cart:hover {
    background-color: var(--color-accent);
    color: var(--color-text);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    opacity: 1;
  }

  .header-cart:active {
    background-color: var(--color-text);
    color: var(--color-accent);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    opacity: 1;
  }

  /* Staggered fade-in on page load — left to right, top to bottom (or menu+cart on mobile) */
  .nav-link,
  .header-cart,
  .header-mobile-toggle {
    opacity: 0;
    transform: translateY(-6px);
    animation: header-item-in 0.22s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .header-mobile-toggle { animation-delay: 0.04s; }

  .nav-link:nth-child(1) { animation-delay: 0.04s; }
  .nav-link:nth-child(2) { animation-delay: 0.08s; }
  .nav-link:nth-child(3) { animation-delay: 0.12s; }
  .nav-link:nth-child(4) { animation-delay: 0.16s; }
  .nav-link:nth-child(5) { animation-delay: 0.20s; }
  .nav-link:nth-child(6) { animation-delay: 0.24s; }
  .nav-link:nth-child(7) { animation-delay: 0.28s; }
  .nav-link:nth-child(8) { animation-delay: 0.32s; }

  /* Cart appears after the nav links — fixed delay since it lives outside .header-nav */
  .header-cart { animation-delay: 0.36s; }

  @keyframes header-item-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .nav-link,
    .header-cart,
    .header-mobile-toggle {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ]
}
{% endschema %}
