<section class="main-product color-{{ section.settings.color_scheme }}">
  {% render 'json-ld-product', product: product %}

  {%- comment -%}
    Background slider: product.media from index 2 onwards (the first two
    media entries are reserved — media[0] is rendered inside Box 1 as the
    product render; media[1] is currently unused but kept reserved per spec).
  {%- endcomment -%}
  {%- if product.media.size > 2 -%}
    <product-bg-slider class="product-bg-slider" aria-hidden="true">
      <div class="product-bg-slider-viewport">
        <div class="product-bg-slider-container">
          {%- for media in product.media offset: 2 -%}
            <div class="product-bg-slider-slide">
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  {{ media | image_url: width: 2400 | image_tag:
                    loading: 'lazy',
                    alt: '',
                    width: media.width,
                    height: media.height
                  }}
                {%- when 'video' -%}
                  {{ media | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                {%- when 'external_video' -%}
                  {%- if media.host == 'youtube' -%}
                    <iframe
                      src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&mute=1&loop=1&controls=0&playlist={{ media.external_id }}"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- elsif media.host == 'vimeo' -%}
                    <iframe
                      src="https://player.vimeo.com/video/{{ media.external_id }}?autoplay=1&muted=1&loop=1&controls=0"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- endif -%}
                {%- when 'model' -%}
                  {{ media | model_viewer_tag }}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </product-bg-slider>
  {%- endif -%}

  <product-form class="product-boxes" data-section-id="{{ section.id }}">
    <script type="application/json" class="product-json">
      {{ product | json }}
    </script>

    {%- form 'product', product -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      {%- comment -%} Box 1: eyebrow + title + product render. The product
                       description lives in the "Details" accordion below, and
                       buy controls live in their own Box at the end of the stack. {%- endcomment -%}
      <div class="product-box product-box-main">
        <header class="section-lockup">
          <p class="text-h1">4 PACK</p>
          <h1 class="text-h2 product-box-title">{{ product.title }}</h1>
        </header>

        {%- comment -%}
          Box render: prefer the product's `custom.product_render_video`
          metafield (File reference, hand-rendered 3D loop) over product.media[0].
          Falls back to the primary media if the metafield isn't set so the
          PDP doesn't break for products that haven't been authored yet.
        {%- endcomment -%}
        {%- assign render_video = product.metafields.custom.product_render_video.value -%}
        {%- assign primary_media = product.media[0] -%}
        {%- if render_video != blank or primary_media -%}
          <div class="product-box-render">
            {%- if render_video != blank -%}
              <video
                autoplay
                loop
                muted
                playsinline
                preload="metadata"
                aria-label="{{ product.title }}"
              >
                <source src="{{ render_video.url }}">
              </video>
            {%- else -%}
              {%- case primary_media.media_type -%}
                {%- when 'image' -%}
                  {{ primary_media | image_url: width: 1200 | image_tag:
                    loading: 'eager',
                    alt: primary_media.alt | default: product.title,
                    width: primary_media.width,
                    height: primary_media.height
                  }}
                {%- when 'video' -%}
                  {{ primary_media | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                {%- when 'external_video' -%}
                  {%- if primary_media.host == 'youtube' -%}
                    <iframe
                      src="https://www.youtube.com/embed/{{ primary_media.external_id }}?autoplay=1&mute=1&loop=1&controls=0&playlist={{ primary_media.external_id }}"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title="{{ product.title }}"
                    ></iframe>
                  {%- elsif primary_media.host == 'vimeo' -%}
                    <iframe
                      src="https://player.vimeo.com/video/{{ primary_media.external_id }}?autoplay=1&muted=1&loop=1&controls=0"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title="{{ product.title }}"
                    ></iframe>
                  {%- endif -%}
                {%- when 'model' -%}
                  {{ primary_media | model_viewer_tag }}
              {%- endcase -%}
            {%- endif -%}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} Details accordion: product description {%- endcomment -%}
      {%- if product.description != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.details' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.description }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Box 2: Instructions (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.instructions != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.instructions' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.instructions }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Box 3: Ingredients (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.ingredients != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.ingredients' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.ingredients }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Box 4: Nutritional info (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.nutritional_info != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.nutritional_info' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">+</span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.nutritional_info }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Buy box (last): variants on top (when applicable), then a
                       single row of qty stepper + Add to cart + price. {%- endcomment -%}
      <div class="product-box product-box-buy">
        <div class="product-variants">
          {% render 'product-variant-selector', product: product %}
        </div>

        <div class="product-buy-row">
          <div class="product-buy-controls" data-variant-render="buy-buttons">
            {% render 'product-buy-buttons', product: product, show_quantity: section.settings.show_quantity %}
          </div>

          <div class="product-buy-price" data-variant-render="price">
            {% render 'product-price', product: product %}
          </div>
        </div>
      </div>
    {%- endform -%}
  </product-form>
</section>

<script src="{{ 'product-form.js' | asset_url }}" defer></script>
<script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
<script src="{{ 'product-bg-slider.js' | asset_url }}" defer></script>
<script src="{{ 'quantity-selector.js' | asset_url }}" defer></script>

{% stylesheet %}
  .main-product {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    padding: var(--spacing-m);
  }

  @media (max-width: 899px) {
    .main-product {
      padding: var(--spacing-xs);
    }
  }

  /* Background slider — fills section, sits behind boxes */
  .product-bg-slider {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    overflow: hidden;
  }

  .product-bg-slider-viewport {
    height: 100%;
    overflow: hidden;
  }

  .product-bg-slider-container {
    display: flex;
    height: 100%;
  }

  /* Each slide shrinks to fit its image so multiple slides can sit side-by-side
     in the flex row — neighbours peek at the edges of the viewport. */
  .product-bg-slider-slide {
    flex: 0 0 auto;
    min-width: 0;
    height: 100%;
  }

  /* Images / videos: fill container height, width auto so the intrinsic aspect
     ratio is preserved (object-fit is irrelevant when the box matches the
     media's natural ratio). */
  .product-bg-slider-slide img,
  .product-bg-slider-slide video,
  .product-bg-slider-slide model-viewer {
    width: auto;
    height: 100%;
    display: block;
  }

  /* iframes (YouTube/Vimeo) have no intrinsic ratio — give them a 16:9 box. */
  .product-bg-slider-slide iframe {
    height: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
    display: block;
  }

  /* Boxes column — left-aligned, stacked, sits on top of slider */
  .product-boxes {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
    max-width: 480px;
    width: 100%;
  }

  /* Shared box treatment — solid panel with brand bg */
  .product-box {
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: var(--rad-s);
    padding: var(--spacing-m);
  }

  /* Box 1: main content stack. The eyebrow + title pair is wrapped in a
     .section-lockup which bakes in the canonical xxs gap between them. */
  .product-box-main {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  .product-box-title {
    margin: 0;
  }

  .product-box-render {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--rad-s);
    background: var(--color-bg-dark);
  }

  .product-box-render img,
  .product-box-render video,
  .product-box-render iframe,
  .product-box-render model-viewer {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  .product-box-buy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  /* Single row: [qty] [Add to cart — fills remaining] [price] */
  .product-buy-row {
    display: flex;
    align-items: center;
    gap: var(--spacing-s);
  }

  .product-buy-controls {
    flex: 1;
    min-width: 0;
  }

  .product-buy-price {
    flex: none;
  }

  /* Dark variant of the primary .button for the PDP Add to cart (matches the
     bundle builder's add-to-cart treatment). Same shape/type as .button, just
     swaps the yellow bg for --color-text. Hover inverts to yellow on dark. */
  .product-buy-controls .button {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .product-buy-controls .button:hover {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  .product-variants {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  /* Hide the variants block entirely when it has no options (single-variant
     products) so the row sits flush with the box's top padding. */
  .product-variants:empty {
    display: none;
  }

  .variant-options {
    border: 0;
    margin: 0;
    padding: 0;
  }

  .buy-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-s);
    align-items: stretch;
  }

  .buy-buttons .button {
    flex: 1;
  }

  /* Accordion boxes (Instructions / Ingredients / Nutritional info) */
  .product-accordion {
    padding: 0;
  }

  .product-accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    padding: var(--spacing-s) var(--spacing-m);
    list-style: none;
  }

  .product-accordion summary::-webkit-details-marker {
    display: none;
  }

  .product-accordion-icon {
    flex-shrink: 0;
    transition: transform var(--transition-fast);
  }

  .product-accordion[open] .product-accordion-icon {
    transform: rotate(45deg);
  }

  .product-accordion-content {
    padding: 0 var(--spacing-m) var(--spacing-s);
  }

  product-form.is-loading [data-variant-render] {
    opacity: 0.6;
    pointer-events: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product information",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
