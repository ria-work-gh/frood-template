<section class="main-product color-{{ section.settings.color_scheme }}">
  {% render 'json-ld-product', product: product %}

  {%- comment -%}
    Background slider: product.media from index 2 onwards. The product render
    video inside Box 1 comes from the `custom.product_render_video` metafield,
    not from product.media. The first two media entries remain reserved per spec.
  {%- endcomment -%}
  {%- if product.media.size > 2 -%}
    <product-bg-slider class="product-bg-slider" aria-hidden="true">
      <div class="product-bg-slider-viewport">
        <div class="product-bg-slider-container">
          {%- for media in product.media offset: 2 -%}
            <div class="product-bg-slider-slide">
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  {{ media | image_url: width: 2400 | image_tag:
                    loading: 'lazy',
                    alt: '',
                    width: media.width,
                    height: media.height
                  }}
                {%- when 'video' -%}
                  {{ media | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true }}
                {%- when 'external_video' -%}
                  {%- if media.host == 'youtube' -%}
                    <iframe
                      src="https://www.youtube.com/embed/{{ media.external_id }}?autoplay=1&mute=1&loop=1&controls=0&playlist={{ media.external_id }}"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- elsif media.host == 'vimeo' -%}
                    <iframe
                      src="https://player.vimeo.com/video/{{ media.external_id }}?autoplay=1&muted=1&loop=1&controls=0"
                      allow="autoplay; encrypted-media"
                      allowfullscreen
                      loading="lazy"
                      title=""
                    ></iframe>
                  {%- endif -%}
                {%- when 'model' -%}
                  {{ media | model_viewer_tag }}
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </product-bg-slider>
  {%- endif -%}

  <product-form class="product-boxes" data-section-id="{{ section.id }}" data-added-message="{{ 'products.product.added_to_cart' | t }}">
    <script type="application/json" class="product-json">
      {{ product | json }}
    </script>

    {%- form 'product', product -%}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

      {%- comment -%} Box 1: title + product render (media[0]) + description + buy controls {%- endcomment -%}
      <div class="product-box product-box-main">
        <div class="product-box-header">
          <h1 class="text-h3 product-box-title">{{ product.title }}</h1>
          <div class="text-h1 product-box-pack-size">(4 pack)</div>
        </div>

        {%- assign render_video = product.metafields.custom.product_render_video.value -%}
        {%- if render_video != blank or product.description != blank -%}
          <div class="product-box-body">
            {%- if render_video != blank -%}
              <div class="product-box-render">
                <product-render-video>
                  {{ render_video | video_tag: autoplay: true, muted: true, controls: false, playsinline: true }}
                </product-render-video>
              </div>
            {%- endif -%}

            {%- if product.description != blank -%}
              <div class="product-box-description typeset">
                {{ product.description }}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        <div class="product-box-buy">
          <div class="product-variants">
            {% render 'product-variant-selector', product: product %}
          </div>
        </div>
      </div>

      {%- comment -%} Box 2: Instructions (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.instructions != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.instructions' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">
            {% render 'icon-add' %}
            {% render 'icon-remove' %}
          </span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.instructions | metafield_tag }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Box 3: Ingredients (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.ingredients != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.ingredients' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">
            {% render 'icon-add' %}
            {% render 'icon-remove' %}
          </span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.ingredients | metafield_tag }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Box 4: Nutritional info (metafield) {%- endcomment -%}
      {%- if product.metafields.custom.nutritional_info != blank -%}
        <details class="product-box product-accordion">
          <summary>
            <span class="text-ui">{{ 'products.product.nutritional_info' | t }}</span>
            <span class="product-accordion-icon" aria-hidden="true">
            {% render 'icon-add' %}
            {% render 'icon-remove' %}
          </span>
          </summary>
          <div class="product-accordion-content typeset">
            {{ product.metafields.custom.nutritional_info | metafield_tag }}
          </div>
        </details>
      {%- endif -%}

      {%- comment -%} Buy dock: sits under all the content boxes, sticks through
         the product-recommendations section via the wrapping custom element. {%- endcomment -%}
      <sticky-buy-dock class="sticky-buy-dock">
        <div class="product-buy-dock" data-variant-render="buy-buttons">
          {% render 'product-buy-buttons', product: product, show_quantity: section.settings.show_quantity %}
        </div>
      </sticky-buy-dock>
    {%- endform -%}
  </product-form>
</section>

<script src="{{ 'product-form.js' | asset_url }}" defer></script>
<script src="{{ 'embla-carousel.umd.js' | asset_url }}" defer></script>
<script src="{{ 'product-bg-slider.js' | asset_url }}" defer></script>
<script src="{{ 'quantity-selector.js' | asset_url }}" defer></script>
<script src="{{ 'product-render-video.js' | asset_url }}" defer></script>
<script src="{{ 'sticky-buy-dock.js' | asset_url }}" defer></script>

{% stylesheet %}
  .main-product {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    padding: var(--spacing-xxs);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 900px) {
    .main-product {
      height: 100vh;
      min-height: 0;
    }
  }

  /* Mobile (<600px): section flows naturally — slider sits at the top,
     boxes stack underneath. Slider is taken out of position:absolute and
     given a 1:1 box so it has measurable height. */
  @media (max-width: 599px) {
    .main-product {
      min-height: 0;
    }
  }

  /* Background slider — fills section, sits behind boxes */
  .product-bg-slider {
    position: absolute;
    inset: 0;
    z-index: 0;
    display: block;
    overflow: hidden;
  }

  @media (max-width: 599px) {
    .product-bg-slider {
      position: relative;
      inset: auto;
      height: 75vh;
      /* Bleed past the section's xxs padding on the sides so the slider is
         edge-to-edge horizontally. Top keeps the section's xxs padding for
         breathing room; bottom flows into the boxes below. */
      margin-inline: calc(-1 * var(--spacing-xxs));
    }
  }

  .product-bg-slider-viewport {
    height: 100%;
    overflow: hidden;
  }

  .product-bg-slider-container {
    display: flex;
    height: 100%;
  }

  .product-bg-slider-slide {
    flex: 0 0 100%;
    min-width: 0;
    height: 100%;
  }

  .product-bg-slider-slide img,
  .product-bg-slider-slide video,
  .product-bg-slider-slide iframe,
  .product-bg-slider-slide model-viewer {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  @media (min-width: 900px) {
    .product-bg-slider-slide {
      flex: 0 0 auto;
      width: auto;
    }

    .product-bg-slider-slide img,
    .product-bg-slider-slide video,
    .product-bg-slider-slide iframe,
    .product-bg-slider-slide model-viewer {
      width: auto;
      height: 100%;
      object-fit: contain;
    }
  }

  /* Boxes column — left-aligned, stacked, sits on top of slider. Stretches
     to fill the section so the buy-dock has room to sticky-scroll.
     z-index: 3 lifts the whole column above later-in-DOM section overlays
     (e.g. fullbleed-frame::after at z-index 1, fullbleed-caption at z-index 2)
     so the sticky dock stays visible when scrolling past those sections.
     Still below header (z-index 9) and footer (z-index 10). */
  .product-boxes {
    position: relative;
    z-index: 3;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
    max-width: 480px;
    width: 100%;
    flex: 1;
    min-height: 0;
  }

  /* Desktop collision-avoidance with the centered .header-nav (max-width: 400px).
     Nav left edge sits at (100vw - 400px) / 2. The column's right edge can't cross
     that line, so we cap its max-width to that gap minus the section's left
     padding (xxs) and a breathing gap of m (24px) between the column and the nav.
     Above ~1424px the cap hits the 480px ceiling — same as before. Below that,
     the column shrinks proportionally. */
  @media (min-width: 900px) {
    .product-boxes {
      max-width: min(480px, calc((100vw - 400px) / 2 - var(--spacing-xxs) - var(--spacing-m)));
    }
  }

  /* The Shopify {% form %} wraps the boxes — make it pass flex through
     and fill .product-boxes so the buy-dock's containing block extends
     to the section's bottom edge */
  .product-boxes form {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xxxs);
    flex: 1;
    min-height: 0;
  }

  /* Shared box treatment — solid panel with brand bg */
  .product-box {
    background: var(--color-bg-dark);
    color: var(--color-text);
    border-radius: var(--rad-s);
    padding: var(--spacing-xs);
  }

  /* Box 1: main content stack — uniform spacing between children EXCEPT
     the last child (the buy/variants block), which sits flush against
     the box's bottom padding. */
  .product-box-main {
    display: flex;
    flex-direction: column;
  }

  .product-box-main > * + * {
    margin-top: var(--spacing-s);
  }

  .product-box-main > :last-child {
    margin-top: 0;
  }

  /* Render + description wrapper. Stacked by default; flexes side-by-side
     on tablet (see tablet rules below). Sits between header and buy inside
     .product-box-main. */
  .product-box-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  /* Tablet (600–899px): boxes column is 64% wide, anchored bottom-left of
     the section; render + description sit side-by-side inside box 1. */
  @media (min-width: 600px) and (max-width: 899px) {
    .product-boxes {
      max-width: none;
      width: 64%;
      flex: 0 0 auto;
      align-self: flex-start;
      margin-top: auto;
    }

    .product-box-body {
      flex-direction: row;
      align-items: flex-start;
    }

    .product-box-body > * {
      flex: 1;
      min-width: 0;
    }
  }

  .product-box-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--spacing-s);
  }

  .product-box-title {
    margin: 0;
  }

  /* Price sits in the header — force brand text colour, ignoring
     the snippet's default .text-light treatment */
  .product-box-price,
  .product-box-price * {
    color: var(--color-text);
  }

  .product-box-render {
    width: 100%;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    border-radius: var(--rad-s);
    background: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Images/iframes/3D models still fill the box edge-to-edge */
  .product-box-render img,
  .product-box-render iframe,
  .product-box-render model-viewer {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  /* Product render video scales down to 85% of the box, centered by the
     flex parent. The <video> inside the wrapper fills the wrapper 100%. */
  .product-box-render product-render-video {
    display: block;
    width: 85%;
    height: 85%;
  }

  .product-box-render product-render-video video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border: 0;
  }

  .product-box-buy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-s);
  }

  .product-variants {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-xs);
  }

  .variant-options {
    border: 0;
    margin: 0;
    padding: 0;
  }

  .buy-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-s);
    align-items: stretch;
  }

  .buy-buttons .button {
    flex: 1;
  }

  /* Accordion boxes (Instructions / Ingredients / Nutritional info) */
  .product-accordion {
    padding: 0;
    /* Lets ::details-content animate to/from `auto` height. Modern browsers
       only; older browsers fall back to instant open/close. */
    interpolate-size: allow-keywords;
  }

  .product-accordion summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    cursor: pointer;
    padding: var(--spacing-xs);
    list-style: none;
  }

  .product-accordion summary::-webkit-details-marker {
    display: none;
  }

  .product-accordion-icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    width: var(--type-ui-size);
    height: var(--type-ui-size);
  }

  /* Stack add/remove on top of each other and crossfade between them.
     Replaces the previous display:none swap (which was instant + non-animatable). */
  .product-accordion-icon svg {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    transition: opacity var(--transition-fast);
  }

  .product-accordion-icon svg:nth-child(2) {
    opacity: 0;
  }

  .product-accordion[open] .product-accordion-icon svg:nth-child(1) {
    opacity: 0;
  }

  .product-accordion[open] .product-accordion-icon svg:nth-child(2) {
    opacity: 1;
  }

  /* Animate the open/close. ::details-content is the wrapper around everything
     inside <details> except <summary>. block-size animates 0 → auto thanks to
     interpolate-size on the parent. content-visibility with allow-discrete
     keeps the content rendered during the close animation, then hides it. */
  .product-accordion::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size var(--transition-fast),
      content-visibility var(--transition-fast) allow-discrete;
  }

  .product-accordion[open]::details-content {
    block-size: auto;
  }

  .product-accordion-content {
    padding: var(--spacing-s) var(--spacing-xs) var(--spacing-xs);
  }

  @media (prefers-reduced-motion: reduce) {
    .product-accordion::details-content,
    .product-accordion-icon svg {
      transition: none;
    }
  }

  /* Buy dock — sits beneath all content boxes. The <sticky-buy-dock>
     wrapper (assets/sticky-buy-dock.js) extends the sticky range past
     the section boundary: it pins the dock at top: var(--header-height)
     while .product-recommendations is in view, and releases it after
     recommendations has scrolled past. CSS sticky here is the no-JS
     fallback — it still pins through the main-product section. */
  sticky-buy-dock {
    display: block;
  }

  .product-buy-dock {
    padding: 0;
  }

  /* Sticky behavior only on desktop (≥900px). Below that the dock just
     sits at the bottom of the column in normal flow. */
  @media (min-width: 900px) {
    .product-buy-dock {
      position: sticky;
      top: var(--spacing-xxs);
      z-index: 2;
    }
  }

  /* Quantity selector in the PDP buy dock — restyled to match the
     bg-dark content boxes (no border, no inner dividers). The inner
     button padding alone matches the accordion summary's xxs padding,
     so the wrapper itself has no padding — keeps total height equal
     to the dropdown toggles above. */
  .product-buy-dock .quantity-selector {
    background-color: var(--color-bg-dark);
    border: 0;
    padding: 0;
  }

  .product-buy-dock .quantity-selector button {
    padding: var(--spacing-xs);
    width: auto;
  }

  .product-buy-dock .quantity-selector button svg {
    width: 10px;
    height: 10px;
  }

  .product-buy-dock .quantity-selector input {
    background-color: transparent;
    border-left: 0;
    border-right: 0;
    padding: 0 var(--spacing-xxs);
    width: 3em;
  }

  /* Qty selector + add-to-cart sit side-by-side, span the box width
     with a tight xxxs gap. Add-to-cart uses .text-ui typography
     (overriding the brand .button's default text-h1 style for this
     context). */
  .product-buy-dock .buy-buttons {
    gap: var(--spacing-xxxs);
  }

  .product-buy-dock .buy-buttons quantity-selector {
    display: flex;
    flex-shrink: 0;
  }

  .product-buy-dock .buy-buttons quantity-selector .quantity-selector {
    height: 100%;
  }

  .product-buy-dock .button {
    padding: var(--spacing-xs);
    justify-content: space-between;
    gap: var(--spacing-s);
    font-size: var(--type-ui-size);
    font-weight: 500;
    line-height: 1.2em;
    letter-spacing: 0;
    text-transform: none;
  }

  product-form.is-loading [data-variant-render] {
    opacity: 0.6;
    pointer-events: none;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product information",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "checkbox",
      "id": "show_quantity",
      "label": "Show quantity selector",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
