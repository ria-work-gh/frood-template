{%- comment -%}
  Cart drawer — a floating "island" overlay that scales in from the top-right.
  Renders the native Shopify cart (cart-items + cart-totals, or cart-empty),
  refreshed via Shopify's Section Rendering API. Listens on `document` for
  `cart:item-added` and `cart:updated` — both swap the body; neither auto-opens
  the drawer (add-to-cart shows a success toast, and the drawer opens on
  cart-icon click). Quantity changes and removes inside the drawer go through
  the embedded <cart-items> component (assets/cart-items.js).

  Section id `cart-drawer` is the key for ?section_id=cart-drawer and
  bundled-sections POST bodies (`sections: ['cart-drawer']`).
{%- endcomment -%}
<cart-drawer id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-hidden="true" aria-label="{{ 'cart.drawer.title' | t }}">
  <div class="cart-drawer-overlay" data-overlay></div>

  <div class="cart-drawer-panel">
    <div class="cart-drawer-bar">
      <button class="cart-drawer-close" data-close aria-label="{{ 'cart.drawer.close' | t }}">
        {% render 'icon-close' %}
      </button>
    </div>
    <div class="cart-drawer-content" data-drawer-body>
      <cart-items>
        {%- if cart.item_count > 0 -%}
          {% render 'cart-items', cart: cart %}
          {% render 'cart-totals', cart: cart %}
        {%- else -%}
          {% render 'cart-empty' %}
        {%- endif -%}
      </cart-items>
    </div>
  </div>
</cart-drawer>

<script type="module" src="{{ 'cart-items.js' | asset_url }}"></script>
<script type="module" src="{{ 'quantity-selector.js' | asset_url }}"></script>
<script type="module" src="{{ 'cart-drawer.js' | asset_url }}"></script>
<script src="{{ 'cart-items.js' | asset_url }}" defer></script>
<script src="{{ 'quantity-selector.js' | asset_url }}" defer></script>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 99;
    pointer-events: none;
  }

  .cart-drawer.is-open {
    pointer-events: auto;
  }

  /* Click-catcher + subtle frosted backdrop behind the island. */
  .cart-drawer-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-overlay);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .cart-drawer.is-open .cart-drawer-overlay {
    opacity: 1;
  }

  /* Island: a content-sized card pinned under the top-right cart button. */
  .cart-drawer-panel {
    position: absolute;
    top: calc(var(--header-height) + var(--spacing-xxs));
    right: var(--spacing-xxs);
    width: 360px;
    max-width: calc(100vw - var(--spacing-s));
    display: flex;
    flex-direction: column;
    padding: var(--spacing-s);
    border-radius: var(--rad-s);
    background: var(--color-bg);
    transform-origin: top right;
    transform: scale(0.96) translateY(-8px);
    opacity: 0;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .cart-drawer.is-open .cart-drawer-panel {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .cart-drawer-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--spacing-xs);
  }

  .cart-drawer-close {
    display: block;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 0;
  }

  .cart-drawer-content {
    max-height: calc(100vh - var(--header-height) - var(--spacing-l));
    overflow-y: auto;
  }

  /* Loading state during refresh — dim contents while we swap. */
  .cart-drawer-content cart-items.is-loading {
    opacity: 0.5;
    pointer-events: none;
  }

  body.drawer-open {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-drawer-overlay,
    .cart-drawer-panel {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer",
  "class": "cart-drawer-section",
  "settings": []
}
{% endschema %}
</content>
</invoke>