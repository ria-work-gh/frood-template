{%- comment -%}
  Cart drawer — a floating "island" overlay that scales in from the top-right,
  styled to match the bundle builder's "Your Box" column. A second view over
  the bundle store: renders the shared bundle-cart snippet from localStorage,
  with working remove buttons + checkout. No native Shopify cart involvement —
  the bundle is this store's only purchase path.
{%- endcomment -%}
<cart-drawer id="cart-drawer" class="cart-drawer" role="dialog" aria-modal="true" aria-hidden="true" aria-label="{{ 'cart.drawer.title' | t }}">
  <div class="cart-drawer-overlay" data-overlay></div>

  <div class="cart-drawer-panel">
    <div class="cart-drawer-bar">
      <button class="cart-drawer-close" data-close aria-label="{{ 'cart.drawer.close' | t }}">
        {% render 'icon-close' %}
      </button>
    </div>
    <div class="cart-drawer-content">
      {% render 'bundle-cart' %}
    </div>
  </div>
</cart-drawer>

<script type="module" src="{{ 'cart-drawer.js' | asset_url }}"></script>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: 0;
    z-index: 99;
    pointer-events: none;
  }

  .cart-drawer.is-open {
    pointer-events: auto;
  }

  /* Click-catcher + subtle frosted backdrop behind the island. */
  .cart-drawer-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-overlay);
    backdrop-filter: blur(var(--blur));
    -webkit-backdrop-filter: blur(var(--blur));
    opacity: 0;
    transition: opacity var(--transition-fast);
  }

  .cart-drawer.is-open .cart-drawer-overlay {
    opacity: 1;
  }

  /* Island: a content-sized card pinned under the top-right cart button,
     matching the bundle builder's "Your Box" column (300px, --color-bg,
     --rad-s, --spacing-xxs padding). Scales in from its top-right corner. */
  .cart-drawer-panel {
    position: absolute;
    top: calc(var(--header-height) + var(--spacing-xxs));
    right: var(--spacing-xxs);
    width: 300px;
    max-width: calc(100vw - var(--spacing-s));
    display: flex;
    flex-direction: column;
    padding: var(--spacing-xxs);
    border-radius: var(--rad-s);
    background: var(--color-bg);
    transform-origin: top right;
    transform: scale(0.96) translateY(-8px);
    opacity: 0;
    transition: transform var(--transition-fast), opacity var(--transition-fast);
  }

  .cart-drawer.is-open .cart-drawer-panel {
    transform: scale(1) translateY(0);
    opacity: 1;
  }

  .cart-drawer-bar {
    display: flex;
    justify-content: flex-end;
    margin-bottom: var(--spacing-xxs);
  }

  .cart-drawer-close {
    display: block;
    background: none;
    border: none;
    cursor: pointer;
    line-height: 0;
  }

  .cart-drawer-content {
    max-height: calc(100vh - var(--header-height) - var(--spacing-l));
    overflow-y: auto;
  }

  /* The shared "Your Box" panel is itself a card on the bundle page; in the
     island the .cart-drawer-panel is the card, so flatten the snippet chrome. */
  .cart-drawer .bundle-cart {
    background: transparent;
    border-radius: 0;
    padding: 0;
  }

  body.drawer-open {
    overflow: hidden;
  }

  @media (prefers-reduced-motion: reduce) {
    .cart-drawer-overlay,
    .cart-drawer-panel {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Cart drawer",
  "class": "cart-drawer-section",
  "settings": []
}
{% endschema %}
