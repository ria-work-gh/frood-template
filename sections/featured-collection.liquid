{%- comment -%}
  Frood Featured Collection — editorial heading (eyebrow + heading + CTA) above a product grid.
  Mobile: schema-selectable carousel (horizontal scroll-snap) or 1-column grid.
  Tablet (≥600px): 2-column grid.
  Desktop (≥900px): 4-column grid.
  See CLAUDE.md → "Frood Homepage Sections" for rules.
{%- endcomment -%}

<section class="featured-collection color-{{ section.settings.color_scheme }}">
  <header class="featured-collection-header section-lockup">
    {%- if section.settings.eyebrow != blank -%}
      <h1 class="text-h1">{{ section.settings.eyebrow }}</h1>
    {%- endif -%}

    {%- if section.settings.heading != blank -%}
      <h3 class="text-h3">{{ section.settings.heading | newline_to_br }}</h3>
    {%- endif -%}

    {%- if section.settings.button_text != blank -%}
      <a
        class="button"
        href="{{ section.settings.button_link | default: '#' }}"
      >
        {{ section.settings.button_text }}
      </a>
    {%- endif -%}
  </header>

  {%- if section.settings.collection != blank -%}
    <div class="featured-collection-products mobile-{{ section.settings.mobile_layout }}">
      {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="featured-collection-products mobile-{{ section.settings.mobile_layout }}">
      {%- for i in (1..section.settings.products_to_show) -%}
        <div class="placeholder-card" aria-hidden="true"></div>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .featured-collection {
    padding: var(--spacing-xs);
    color: var(--color-text);
    background-color: var(--color-bg);
  }

  @media (min-width: 900px) {
    .featured-collection {
      padding: var(--spacing-m);
    }
  }

  /* Lockup alignment + internal gaps come from .section-lockup (see base.css §22).
     This rule only handles the gap between the lockup and the product grid below. */
  .featured-collection-header {
    margin-bottom: var(--spacing-l);
  }

  .featured-collection-header h3 {
    max-width: 36ch;
  }

  /* Mobile: carousel (horizontal scroll-snap).
     Bleeds past the section's right padding so cards extend to the screen edge —
     gives a clear scroll affordance. First card aligns with the left padding. */
  .featured-collection-products.mobile-carousel {
    display: flex;
    gap: var(--spacing-xs);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    padding-bottom: var(--spacing-xs);
    margin-right: calc(-1 * var(--spacing-xs));
  }

  .featured-collection-products.mobile-carousel::-webkit-scrollbar {
    display: none;
  }

  .featured-collection-products.mobile-carousel > * {
    flex: 0 0 75%;
    scroll-snap-align: start;
  }

  /* Mobile: stacked grid (1 column) */
  .featured-collection-products.mobile-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-xs);
  }

  /* Tablet+: 2-column grid (overrides both mobile modes).
     Also resets the carousel's right-edge bleed and flex item sizing. */
  @media (min-width: 600px) {
    .featured-collection-products.mobile-carousel,
    .featured-collection-products.mobile-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--spacing-xs);
      overflow: visible;
      padding-bottom: 0;
      margin-right: 0;
    }

    .featured-collection-products.mobile-carousel > * {
      flex: initial;
      scroll-snap-align: none;
    }
  }

  /* Desktop+: 4-column grid */
  @media (min-width: 900px) {
    .featured-collection-products.mobile-carousel,
    .featured-collection-products.mobile-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Placeholder card (when no collection is selected) */
  .placeholder-card {
    aspect-ratio: 3 / 4;
    background: var(--color-border);
    border-radius: var(--rad-s);
    animation: placeholder-pulse 1.5s ease-in-out infinite;
  }

  @keyframes placeholder-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .placeholder-card {
      animation: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured collection",
  "tag": "section",
  "class": "featured-collection-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (h1 — small uppercase label)",
      "default": "Our collection"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading (h3)",
      "info": "Press Enter to add a line break.",
      "default": "Real food, made simple.\nMade for modern home cooks."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label",
      "default": "Our range"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Mobile layout",
      "info": "How products display on mobile. Tablet and desktop are always a grid.",
      "options": [
        { "value": "carousel", "label": "Carousel (horizontal scroll)" },
        { "value": "grid", "label": "Grid (stacked)" }
      ],
      "default": "carousel"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Featured collection"
    }
  ]
}
{% endschema %}
